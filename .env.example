# Core
DATABASE_URL=postgresql://user:pass@localhost:5432/pagepilot
APP_URL=http://localhost:3000
APP_SECRET=change-me-32-random-bytes
AUTH_SECRET=change-me-32-random-bytes
REVALIDATE_KEY=change-me

# Seed
SEED_SUPERADMIN_EMAIL=admin@example.com
SEED_SUPERADMIN_PASSWORD=

# Storage (ImageKit; media deletes propagate to ImageKit)
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=
IMAGEKIT_FOLDER=/pagepilot

# Optional
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
